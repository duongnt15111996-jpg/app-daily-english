{
  "expo": {
    "name": "dailyenglish",
    "slug": "dailyenglish",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo-daily-english.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/logo-daily-english.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.dailyenglish",
      "permissions": ["android.permission.SCHEDULE_EXACT_ALARM"]
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/logo-daily-english-mono.png",
          "color": "#3B82F6"
        }
      ]
    ],
    "web": {
      "favicon": "./assets/logo-daily-english.png"
    }
  }
}
